# Copie para .env na raiz do monorepo ou em services/api/
# Guia completo: PUSH_NOTIFICATIONS.md

PORT=8081
MONGODB_URI=
MONGODB_DATABASE=monitoramento
CORS_ORIGINS=http://localhost:3000
JWT_SECRET=altere-em-producao
JWT_EXPIRY_HOURS=8

# Push FCM — JSON da service account (Firebase Console → Contas de serviço)
# Coloque o arquivo na raiz do projeto com este nome:
FCM_CREDENTIALS_FILE=./firebase-service-account.json
