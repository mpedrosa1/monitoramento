# Copie para .env na raiz do monorepo ou em services/api/
# Guia completo: PUSH_NOTIFICATIONS.md

PORT=8081
MONGODB_URI=
MONGODB_DATABASE=monitoramento
CORS_ORIGINS=http://localhost:3000
# Permite origens da rede local (192.168.x, 10.x, etc.) — útil para acessar pelo IP na LAN
CORS_ALLOW_LAN=true
JWT_SECRET=altere-em-producao
JWT_EXPIRY_HOURS=8

# Push FCM — JSON da service account (Firebase Console → Contas de serviço)
# Coloque o arquivo na raiz do projeto com este nome:
FCM_CREDENTIALS_FILE=./firebase-service-account.json

# Rastreamento Rota Exata (homologação: https://api-dev.rotaexata.com.br)
# Senha com # ou espaços: use aspas → ROTAEXATA_PASSWORD="#suaSenha"
ROTAEXATA_BASE_URL=
ROTAEXATA_EMAIL=
ROTAEXATA_PASSWORD=
ROTAEXATA_SYNC_INTERVAL_SEC=60
